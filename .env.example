# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=osync
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=osync

# ── MinIO (S3-compatible storage) ────────────────────────────
S3_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_8_CHARS
S3_BUCKET=osync-bucket
S3_REGION=us-east-1

# MinIO server-side encryption key
# Format: name:base64(32 random bytes)
# Generate: echo "osync-key:$(openssl rand -base64 32)"
MINIO_KMS_SECRET_KEY=osync-key:CHANGE_ME_BASE64_32_BYTES

# ── Auth ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGE_ME_HEX_64_CHARS
SYNC_TOKEN_SECRET=CHANGE_ME_DIFFERENT_HEX_64_CHARS

# ── App ───────────────────────────────────────────────────────
PORT=3000
PUBLIC_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com
SELF_HOSTED=true
SYNC_TOKEN_TTL_SECONDS=120
COORDINATOR_DATA_DIR=/data/coordinators

# ── Admin account (first run only) ───────────────────────────
# Set these to auto-create an admin account on first start.
# Remove or leave empty after the account is created.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
